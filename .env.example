# --- Primary: OpenRouter (default model is a :free tier chat model) ---
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: OpenRouter model id (defaults to Nemotron 3 Super free)
# SEO_AGENT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# OpenRouter attribution (recommended)
OPENROUTER_HTTP_REFERER=http://localhost:3040
OPENROUTER_APP_TITLE=MenteMaestra SEO Agent

# --- Fallback: OpenAI (only if OPENROUTER_API_KEY is unset) ---
# OPENAI_API_KEY=
